# Server
PORT=3000
NODE_ENV=development

# Database (Supabase or local Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/moneycoach

# Knot API
KNOT_CLIENT_ID=your_knot_client_id
KNOT_CLIENT_SECRET=your_knot_client_secret
KNOT_REDIRECT_URI=http://localhost:3000/auth/knot/callback
KNOT_API_BASE_URL=https://api.knotapi.com

# Photon API (add later)
PHOTON_API_KEY=your_photon_key
PHOTON_PHONE_NUMBER=+1234567890

# Claude API (add later)
ANTHROPIC_API_KEY=your_anthropic_key

# Feature flags
ENABLE_PROACTIVE_ALERTS=false